---
import { getCollection, render } from 'astro:content';
import Blog from '../../layouts/Blog.astro';
import StructuredData from '../../components/StructuredData.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Build chronological neighbors for prev/next
const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const previousPost = currentIndex > 0
  ? { title: allPosts[currentIndex - 1].data.title, url: `/blog/${allPosts[currentIndex - 1].id}/` }
  : undefined;
const nextPost = currentIndex < allPosts.length - 1
  ? { title: allPosts[currentIndex + 1].data.title, url: `/blog/${allPosts[currentIndex + 1].id}/` }
  : undefined;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://signetai.sh';
const pageUrl = `${siteUrl}/blog/${post.id}/`;

// Recommended posts: score by shared tags, sort by score then date
const currentTags = new Set(post.data.tags);
const recommended = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    post: p,
    score: p.data.tags.filter((t: string) => currentTags.has(t)).length,
  }))
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.date.getTime() - a.post.data.date.getTime())
  .slice(0, 3)
  .map((r) => ({
    title: r.post.data.title,
    url: `/blog/${r.post.id}/`,
    image: r.post.data.image,
  }));
---

<Blog
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  author={post.data.author}
  tags={post.data.tags}
  image={post.data.image}
  headings={headings}
  previousPost={previousPost}
  nextPost={nextPost}
  pageUrl={pageUrl}
  recommendedPosts={recommended}
>
  <StructuredData data={{
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString().slice(0, 10),
    author: {
      '@type': 'Person',
      name: post.data.author,
    },
    url: pageUrl,
    publisher: {
      '@type': 'Organization',
      name: 'SignetAI',
      url: siteUrl,
    },
  }} />
  <StructuredData data={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: pageUrl },
    ],
  }} />
  <Content />
</Blog>
